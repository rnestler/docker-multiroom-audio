# User UID:GID for container processes (run 'id -u' and 'id -g')
USER_ID=1000
GROUP_ID=1000

# Host network interface to attach the ipvlan network to
NETWORK_INTERFACE=wlan0

# LAN network settings
SUBNET=192.168.0.0/24
GATEWAY=192.168.0.254
IP_RANGE=192.168.0.208/28

# Static IP for the container (must be within IP_RANGE, outside DHCP range)
CONTAINER_IP=192.168.0.210
